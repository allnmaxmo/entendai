{
  "name": "entendai",
  "version": "1.0.0",
  "description": "ENTENDAI - Aplicacao simples com Cloudflare Pages Functions e Workers AI para explicar termos em portugues.",
  "type": "module",
  "scripts": {
    "build": "node -e \"require('node:fs').accessSync('public/index.html')\"",
    "dev": "wrangler pages dev public --ai AI",
    "deploy": "wrangler pages deploy public --project-name entendai"
  },
  "devDependencies": {
    "wrangler": "^4.23.0"
  }
}
